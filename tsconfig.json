{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "skipLibCheck": true,
        "lib": ["ESNext", "DOM"],
        "types": ["node"],
        "baseUrl": ".",
        "paths": {
            "@core/*":      ["src/core/*"],
            "@rendering/*": ["src/rendering/*"],
            "@physics/*":   ["src/physics/*"],
            "@player/*":    ["src/player/*"],
            "@world/*":     ["src/world/*"]
        }
    },
    "include": ["src", "vite.config.ts"]
}
